# --- Сетевые Настройки и Безопасность ---
# ФЛАГ: Включение/отключение ротации IP
# Установите False для полного отключения смены IP (все запросы через прямое соединение).
# Установите True для включения ротации IP согласно стратегии IP_ROTATION_STRATEGY.
IP_ROTATION_ENABLED=True
# Стратегии смены IP через запятую. Доступные: proxy_fallback, tor_fallback
IP_ROTATION_STRATEGY=proxy_fallback,tor_fallback
# Список URL-адресов (через запятую) для загрузки списков HTTP/HTTPS прокси.
# Будут использоваться для динамической ротации IP-адресов.
# Примеры бесплатных списков. Для продакшена РЕКОМЕНДУЮТСЯ платные провайдеры.
PROXY_SOURCES=https://raw.githubusercontent.com/proxifly/free-proxy-list/main/proxies/protocols/http/data.txt,https://raw.githubusercontent.com/TheSpeedX/SOCKS-List/master/http.txt,https://raw.githubusercontent.com/Zaeem20/FREE_PROXIES_LIST/master/https.txt,https://raw.githubusercontent.com/jetkai/proxy-list/main/online-proxies/txt/proxies-https.txt,https://raw.githubusercontent.com/MuRongPIG/Proxy-Master/main/http.txt
# URL для проверки работоспособности прокси. Должен возвращать IP-адрес клиента.
PROXY_CHECK_URL=https://api.ipify.org?format=json

# Таймаут в секундах для проверки одного прокси.
PROXY_CHECK_TIMEOUT=15

# Как часто (в секундах) обновлять список рабочих прокси. (1800 = 30 минут)
PROXY_REFRESH_INTERVAL_SECONDS=1800

# Настройки для TOR (используются, если включен tor_fallback)
# Для использования нужно установить и запустить TOR: brew install tor
TOR_PROXY_ENABLED=true
TOR_PROXY_URL=socks5://127.0.0.1:9050
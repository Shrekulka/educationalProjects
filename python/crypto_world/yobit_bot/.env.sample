# .env.sample

DB_ENGINE=postgresql
DB_NAME=crypto_trading_bot
DB_USER=postgres
DB_PASSWORD=your_strong_password_here
DB_HOST=localhost
DB_PORT=5432

BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijk
ALERT_CHAT_ID=123456789
ADMIN_USER_ID=123456789

BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here
BINANCE_TESTNET=True
BINANCE_BASE_URL=https://testnet.binance.vision

KUCOIN_API_KEY=your_kucoin_api_key_here
KUCOIN_SECRET_KEY=your_kucoin_secret_key_here
KUCOIN_PASSPHRASE=your_kucoin_passphrase_here
KUCOIN_SANDBOX=True
KUCOIN_BASE_URL=https://openapi-sandbox.kucoin.com

BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_SECRET_KEY=your_bybit_secret_key_here
BYBIT_TESTNET=True
BYBIT_BASE_URL=https://api-testnet.bybit.com

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your_redis_password
REDIS_PRICE_TTL=60

MAX_POSITION_SIZE=100.0
MIN_PROFIT_THRESHOLD=0.5
MAX_SLIPPAGE=0.2
MAX_OPEN_POSITIONS=3
POSITION_SIZE_PERCENT=10.0

MIN_PRICE_DIFFERENCE=0.3
BINANCE_MAKER_FEE=0.1
BINANCE_TAKER_FEE=0.1
KUCOIN_MAKER_FEE=0.1
KUCOIN_TAKER_FEE=0.1
ORDER_TIMEOUT=30
ARBITRAGE_CHECK_INTERVAL=1

LOG_LEVEL=INFO
LOG_FILE_PATH=logs/crypto_bot.log
LOG_MAX_SIZE=100
LOG_BACKUP_COUNT=5

ENABLE_TELEGRAM_ALERTS=True
ALERT_MIN_LEVEL=WARNING

WS_MAX_RECONNECT_ATTEMPTS=10
WS_RECONNECT_DELAY=5
WS_PING_TIMEOUT=10

WORKER_COUNT=4
ORDER_BUFFER_SIZE=1000
HTTP_TIMEOUT=10

DEBUG=True
DEV_MODE=True
LOG_API_CALLS=True

ENCRYPTION_KEY=your_32_character_encryption_key_here_12345
SECRET_KEY=your_super_secret_key_for_app_security_here

AUTO_BACKUP_ENABLED=True
BACKUP_INTERVAL=24
BACKUP_PATH=backups/

BINANCE_RECV_WINDOW=5000
BINANCE_REQUEST_TIMEOUT=10

KUCOIN_REQUEST_TIMEOUT=10

BYBIT_RECV_WINDOW=5000
BYBIT_REQUEST_TIMEOUT=10

TEST_SYMBOLS=BTCUSDT,ETHUSDT,ADAUSDT
USE_MOCK_DATA=False
TEST_POSITION_SIZE=10.0
# ==========================================
# Django Settings
# ==========================================
SECRET_KEY=your-secret-key-here   # Обязательно замени на свой секретный ключ!
DEBUG=True                        # Для разработки. Для продакшена ставь False
# DEBUG=False

ALLOWED_HOSTS=localhost,127.0.0.1
# Для ngrok раскомментируй строку ниже и добавь свой адрес
# ALLOWED_HOSTS=localhost,127.0.0.1,*.ngrok-free.app

# ==========================================
# Database (PostgreSQL)
# ==========================================
DB_ENGINE=postgresql
POSTGRES_DB=task_manager
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Если запускаешь локально через manage.py runserver:
DB_HOST=localhost
DB_PORT=5432

# Если запускаешь в Docker-compose, раскомментируй и закомментируй localhost:
# DB_HOST=db
# DB_PORT=5432

# ==========================================
# CSRF Trusted Origins
# ==========================================
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
# Для ngrok добавь сюда свой адрес, например:
# CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://*.ngrok-free.app

# ==========================================
# Email (для django-allauth)
# ==========================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# Для продакшена можно сменить на SMTP
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend